---
import BaseLayout from './BaseLayout.astro';
import SeaLayers from '../components/SeaLayers.astro';
import TopicBadge from '../components/TopicBadge.astro';
import PhotoReel from '../components/PhotoReel.astro';
import TableOfContents from '../components/TableOfContents.astro';

interface Props {
  title: string;
  topic: string;
  date?: string;
  summary?: string;
  layer?: 'underwater' | 'coastal' | 'sky' | 'parchment' | 'deep';
  slug: string;
  gallery?: Array<{
    src: string;
    caption: string;
    alt?: string;
  }>;
  showToc?: boolean; // default true for entries with gallery (rich narrative entries)
}

const { title, topic, date, summary, layer, slug } = Astro.props;

// Derive mood from topic if no explicit layer
function getMoodFromTopic(t: string): any {
  const map: Record<string, any> = {
    Botany: 'coastal',
    Geology: 'parchment',
    History: 'deep',
    Religion: 'sky',
    Language: 'parchment',
  };
  return map[t] || 'coastal';
}

const mood = layer || getMoodFromTopic(topic);
---

<BaseLayout title={`${title} — Cyprus Logbook`}>
  <SeaLayers mood={mood} />

  <main class="mx-auto max-w-3xl px-5 pt-9 pb-20">
    <!-- Reading surface: warm, slightly lifted page that guarantees readability over any sea layer -->
    <div class="reading-surface bg-[#f9f6f0] border border-black/5 rounded-2xl shadow-[0_1px_0_0_rgba(0,0,0,0.02)] px-6 py-7 md:px-9 md:py-9">
      <div class="mb-5 flex items-center gap-3">
        <a href="/archive" class="text-xs uppercase tracking-[1px] text-[#5c5c5c] hover:text-black">← Archive</a>
        <TopicBadge topic={topic as any} />
      </div>

      <header class="mb-7">
        <h1 class="font-serif text-[38px] leading-[1.03] tracking-[-1.05px] text-[#1c1c1c] md:text-[44px]">
          {title}
        </h1>

        <div class="mt-2.5 flex items-center gap-x-3 text-sm text-[#555]">
          {date && <time datetime={date}>{date}</time>}
          {date && <span class="text-[#999]">·</span>}
          <span class="text-[#555]">Observed in Cyprus</span>
        </div>

        {summary && (
          <p class="mt-3.5 max-w-[60ch] text-[15.2px] leading-relaxed text-[#3a3a3a]">
            {summary}
          </p>
        )}
      </header>

      <!-- Photo reel / carousel for special entries (placed right after the title/summary to match the sketch) -->
      {Astro.props.gallery && Astro.props.gallery.length > 0 && (
        <PhotoReel images={Astro.props.gallery} />
      )}

      <!-- Wikipedia-style Contents table (auto from h2/h3 in prose). Small, elegant, mobile-collapsible. -->
      {(Astro.props.showToc ?? (Astro.props.gallery && Astro.props.gallery.length > 0)) && (
        <TableOfContents />
      )}

      <article class="entry-prose max-w-[66ch]">
        <slot />
      </article>

      <div class="mt-10 pt-5 border-t border-black/5 text-xs text-[#666] flex gap-x-4">
        <a href="/glossary" class="hover:text-black">Explore the glossary</a>
        <span class="opacity-40">·</span>
        <a href="/archive" class="hover:text-black">Return to the archive</a>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .reading-surface {
    /* Slightly warmer and softer than body to feel like a log page */
    box-shadow: 0 10px 30px -15px rgba(0, 0, 0, 0.08);
  }

  /* Use :global so custom prose styles apply to slotted Markdown content (headings, paragraphs etc.) */
  :global(.entry-prose) {
    font-size: 15.4px;
    line-height: 1.73;
    color: #252525;
  }

  :global(.entry-prose h2) {
    font-family: ui-serif, Georgia, 'Times New Roman', serif;
    font-size: 17.2px;
    margin-top: 2.1em;
    margin-bottom: 0.55em;
    letter-spacing: -0.16px;
    color: #1a1a1a;
    font-weight: 600;
  }

  /* Sub-headings (###) — subtle, consistent treatment for reading flow.
     Matches the calm indented "thread" used for h3 items in the Table of Contents.
     No keyword exceptions; every sub-heading gets the same quiet accent. */
  :global(.entry-prose h3) {
    font-family: ui-serif, Georgia, 'Times New Roman', serif;
    font-size: 15.6px;
    margin-top: 1.4em;
    margin-bottom: 0.35em;
    font-weight: 500;
    color: #463a2b;           /* warm stone, calm on cream */
    letter-spacing: -0.08px;
    border-left: 2px solid rgba(70, 58, 43, 0.18);
    padding-left: 0.55rem;
  }

  :global(.entry-prose p) {
    margin-bottom: 1.0em;
  }

  :global(.entry-prose p:last-child) {
    margin-bottom: 0;
  }

  :global(.entry-prose a) {
    color: #222;
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-thickness: 0.5px;
  }

  :global(.entry-prose a:hover) {
    color: #000;
  }
</style>
