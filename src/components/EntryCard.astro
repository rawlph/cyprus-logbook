---
import TopicBadge from './TopicBadge.astro';

interface Props {
  title: string;
  slug: string;
  topic: string;
  summary?: string;
  date?: string;
}

const { title, slug, topic, summary, date } = Astro.props;

// Topic accent colors for the left "log slip" bar
const accent: Record<string, string> = {
  Botany: '#166534',      // deep forest / sea green
  Geology: '#92400e',     // warm sandstone
  History: '#1e3a5f',     // deep navy
  Religion: '#854d0e',    // old gold / saffron
  Language: '#1e40af',    // strong Mediterranean blue
};

const barColor = accent[topic] ?? '#334155';
---

<a
  href={`/entries/${slug}`}
  class="group block overflow-hidden rounded-xl border border-black/5 bg-white/80 transition-all hover:border-black/10 hover:bg-white hover:shadow-sm"
>
  <!-- Colored left log-slip accent -->
  <div class="flex">
    <div class="w-[5px] shrink-0" style={`background-color: ${barColor};`}></div>

    <div class="flex-1 p-4 pt-3.5">
      <!-- Meta row: date + topic -->
      <div class="flex items-center justify-between text-[10px] text-[#6b6b6b]">
        {date && <time class="font-mono tracking-[0.5px]">{date}</time>}
        <TopicBadge topic={topic as any} size="sm" />
      </div>

      <!-- Title -->
      <h3 class="mt-1.5 font-serif text-[16.5px] leading-tight tracking-[-0.12px] text-[#1f1f1f] group-hover:text-black line-clamp-2">
        {title}
      </h3>

      <!-- Very compact one-line hint (optional) -->
      {summary && (
        <p class="mt-1.5 text-[12.8px] leading-snug text-[#555] line-clamp-1">
          {summary}
        </p>
      )}

      <div class="mt-2 text-[10px] text-[#6b6b6b] group-hover:text-[#333] transition-colors">
        Read entry →
      </div>
    </div>
  </div>
</a>
